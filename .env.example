# Vision API Configuration (Optional)
# Used by analyze_image tool for image understanding.
# Not needed by the VLM-Hybrid backend (MinerU manages its own config).

# Your API key (or OPENAI_API_KEY)
VISION_API_KEY=your-api-key-here

# API base URL (OpenAI-compatible)
VISION_BASE_URL=https://api.openai.com/v1

# Model name
VISION_MODEL=gpt-4o

# Max image size in MB (default: 20)
VISION_MAX_IMAGE_SIZE_MB=20

# ── MinerU (VLM-Hybrid backend) ──
# MinerU reads mineru.json (project root) for model paths.
# The template at mineru.json.template uses:
#   models/pipeline  → PDF-Extract-Kit-1.0 (layout/OCR/formula/table models)
#   models/vlm       → MinerU2.5-Pro-2604-1.2B (Qwen2-VL fine-tuned VLM)
#
# Download models into the project:
#   pip install mineru
#   mineru-models-download --models-dir ./models
#
# Then copy the template:
#   cp mineru.json.template mineru.json
#
# MinerU env vars (optional overrides):
# MINERU_PROCESSING_WINDOW_SIZE=64
# MINERU_FORMULA_ENABLE=true
# MINERU_TABLE_ENABLE=true
# MINERU_DEVICE_MODE=auto
